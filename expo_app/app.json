{
  "expo": {
    "name": "Shinkleesh",
    "slug": "shinkleesh",
    "scheme": "shinkleesh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#52FFB8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.albardn2.shinkleesh",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#52FFB8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.albardn2.shinkleesh"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Shinkleesh needs your location to show nearby posts."
        }
      ],
      "./plugins/withDisableExplicitModules"
    ],
    "extra": {
      "eas": {
        "projectId": "2fa16db6-1f05-4cfc-be6e-b615ac3b8166"
      }
    },
    "owner": "albardn2",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2fa16db6-1f05-4cfc-be6e-b615ac3b8166"
    }
  }
}
