# Template for backend/.env — copy to .env and fill in real values.
# .env is gitignored. On CI/CD, the deploy workflows generate this file on the
# server from GitHub Secrets.

DEBUG=false
SECRET_KEY=change-me

# Postgres — used by docker-compose for local dev
POSTGRES_DB=backend
POSTGRES_USER=local
POSTGRES_PASSWORD=local
SQLALCHEMY_DATABASE_URI=postgresql://local:local@db:5432/backend

# OAuth credentials — fill in before enabling social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=

# URL the backend redirects to after OAuth success (web admin app)
FRONTEND_URL=http://localhost:5173
